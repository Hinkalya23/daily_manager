# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=123456789
TELEGRAM_MESSAGE_THREAD_ID=12345

# Timezone for daily report
TIMEZONE=Europe/Moscow
REPORT_HOUR=10
REPORT_MINUTE=0

# Ozon Seller API
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key

# Wildberries APIs
WB_API_TOKEN=your_wb_token

# Optional: if API payloads require fixed date offset from today
REPORT_DAYS_BACK=1

# Optional WB grouped sales-funnel filters (comma-separated). Keep empty to use all products.
WB_BRAND_NAMES=
WB_SUBJECT_IDS=
WB_TAG_IDS=
